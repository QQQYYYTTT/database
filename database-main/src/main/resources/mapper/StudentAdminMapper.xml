<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cd.mapper.StudentAdminMapper">

    <resultMap id="StudentSelfProfileResultMap" type="com.cd.dto.StudentSelfProfileResponse">
        <id property="studentId" column="student_id"/>
        <result property="studentNo" column="student_no"/>
        <result property="name" column="name"/>
        <result property="gender" column="gender"/>
        <result property="birthDate" column="birth_date"/>
        <result property="status" column="status"/>
        <result property="className" column="class_name"/>
        <result property="gradeName" column="grade_name"/>
        <result property="entryYear" column="entry_year"/>
        <result property="majorName" column="major_name"/>
        <result property="collegeName" column="college_name"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="address" column="address"/>
    </resultMap>

    <resultMap id="StudentProfileSnapshotResultMap" type="com.cd.dto.StudentProfileMaskedResponse">
        <id property="studentId" column="student_id"/>
        <result property="studentNo" column="student_no"/>
        <result property="name" column="name"/>
        <result property="gender" column="gender"/>
        <result property="birthDate" column="birth_date"/>
        <result property="status" column="status"/>
        <result property="className" column="class_name"/>
        <result property="gradeName" column="grade_name"/>
        <result property="entryYear" column="entry_year"/>
        <result property="majorName" column="major_name"/>
        <result property="collegeName" column="college_name"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="idCard" column="id_card"/>
        <result property="address" column="address"/>
        <result property="familyIncome" column="family_income"/>
        <result property="bankCard" column="bank_card"/>
    </resultMap>

    <select id="selectCurrentStudentProfile" resultMap="StudentSelfProfileResultMap">
        SELECT s.id AS student_id,
               s.student_no,
               s.name,
               s.gender,
               DATE_FORMAT(s.birth_date, '%Y-%m-%d') AS birth_date,
               s.status,
               ci.class_name,
               gi.grade_name,
               gi.entry_year,
               m.major_name,
               c.college_name,
               ss.phone,
               ss.email,
               ss.address
        FROM `user` u
        JOIN student s ON s.student_no = u.user_name
        JOIN class_info ci ON ci.id = s.class_id
        JOIN grade_info gi ON gi.id = ci.grade_id
        JOIN major m ON m.id = ci.major_id
        JOIN college c ON c.id = m.college_id
        LEFT JOIN student_sensitive ss ON ss.student_id = s.id
        WHERE u.id = #{userId}
        LIMIT 1
    </select>

    <select id="selectLinkedStudentIdByUserId" resultType="long">
        SELECT s.id
        FROM `user` u
        JOIN student s ON s.student_no = u.user_name
        WHERE u.id = #{userId}
        LIMIT 1
    </select>

    <select id="selectStudentProfileSnapshotById" resultMap="StudentProfileSnapshotResultMap">
        SELECT v.student_id,
               v.student_no,
               v.name,
               v.gender,
               DATE_FORMAT(v.birth_date, '%Y-%m-%d') AS birth_date,
               v.status,
               v.class_name,
               v.grade_name,
               v.entry_year,
               v.major_name,
               v.college_name,
               v.phone,
               v.email,
               v.id_card,
               v.address,
               CAST(v.family_income AS CHAR) AS family_income,
               v.bank_card
        FROM v_student_profile v
        WHERE v.student_id = #{studentId}
        LIMIT 1
    </select>

    <update id="updateStudentBasicById">
        UPDATE student
        SET name = #{request.name},
            gender = #{request.gender},
            birth_date = NULLIF(#{request.birthDate}, ''),
            status = #{request.status}
        WHERE id = #{studentId}
    </update>

    <insert id="upsertStudentSensitive">
        INSERT INTO student_sensitive (student_id, phone, email, address)
        VALUES (#{studentId}, #{phone}, #{email}, #{address})
        ON DUPLICATE KEY UPDATE
            phone = VALUES(phone),
            email = VALUES(email),
            address = VALUES(address)
    </insert>

    <delete id="deleteStudentSensitiveByStudentId">
        DELETE FROM student_sensitive
        WHERE student_id = #{studentId}
    </delete>

    <delete id="deleteStudentScoresByStudentId">
        DELETE FROM student_score
        WHERE student_id = #{studentId}
    </delete>

    <delete id="deleteStudentById">
        DELETE FROM student
        WHERE id = #{studentId}
    </delete>

</mapper>
