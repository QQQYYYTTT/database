<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cd.mapper.TestMapper">

    <resultMap id="TestResultMap" type="com.cd.entity.TestEntity">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="age" column="age"/>
        <result property="email" column="email"/>
        <result property="createdTime" column="created_time"/>
        <result property="updatedTime" column="updated_time"/>
    </resultMap>

    <sql id="BaseColumns">
        id, name, age, email, created_time, updated_time
    </sql>

    <select id="selectAll" resultMap="TestResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM test
        ORDER BY id DESC
    </select>

    <select id="selectById" parameterType="long" resultMap="TestResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM test
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.cd.entity.TestEntity"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO test (name, age, email)
        VALUES (#{name}, #{age}, #{email})
    </insert>

    <update id="updateById" parameterType="com.cd.entity.TestEntity">
        UPDATE test
        SET name = #{name},
            age = #{age},
            email = #{email}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM test
        WHERE id = #{id}
    </delete>

</mapper>
